# App
APP_ENV=production
SECRET_KEY=replace-with-strong-secret
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ACCESS_TOKEN_EXPIRE_HOURS=8

# Database
POSTGRES_DB=cafemargin
POSTGRES_USER=cafemargin
POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgresql://cafemargin:replace-with-strong-password@db:5432/cafemargin

# Optional tuning
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Supabase Storage
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_BUCKET_UPLOADS=cafemargin-uploads
SUPABASE_BUCKET_REPORTS=cafemargin-reports
SUPABASE_BUCKET_MODELS=cafemargin-models
SUPABASE_SIGNED_URL_EXPIRES=3600

# Auth rate limiting (seconds)
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=300
LOGIN_BLOCK_SECONDS=600

# Upload limits
MAX_UPLOAD_MB=50
